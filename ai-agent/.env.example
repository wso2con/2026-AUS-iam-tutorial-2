# Client ID of the agent application associated with the created AI agent in Asgardeo
CLIENT_ID=client ID of the agent application

# Client secret of the agent application associated with the created AI agent in Asgardeo
CLIENT_SECRET=client secret of the agent application

# Base URL of your Asgardeo organization.
ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<your organization>

# Redirect URI configured for the Asgardeo application.
REDIRECT_URI=http://localhost:8791

# Agent identifier issued by Asgardeo.
AGENT_ID=agent ID of the agent created in Asgardeo

# Agent secret issued by Asgardeo.
AGENT_SECRET=agent secret of the agent created in Asgardeo

# Base URL of the B2B Next.js app APIs.
APP_BASE_URL=http://localhost:3000

# Scope requested when the autonomous agent switches into the signed-in user's organization to view travel policies.
AGENT_TRAVEL_POLICY_SCOPES=view_travel_policy

# Scope requested in the delegated authorization URL for booking on behalf of the user.
DELEGATED_BOOKING_SCOPES=create_booking

# Optional: scopes requested when a signed-in user's root token must be exchanged into an organization token.
DELEGATED_USER_ORG_SCOPES=openid internal_org_user_mgt_create internal_org_user_mgt_list internal_org_user_mgt_update internal_org_role_mgt_view internal_org_role_mgt_users_update create_travel_policy view_travel_policy update_travel_policy delete_travel_policy view_booking create_booking delete_booking

# Callback URL registered in Asgardeo for delegated user authorization.
OBO_REDIRECT_URI=http://localhost:8791/obo/callback

# Optional resource parameter to include in delegated authorization requests.
OBO_RESOURCE=

# AI model provider: gemini | openai | anthropic | deepseek (default: gemini)
MODEL_PROVIDER=gemini

# Model name for the selected provider.
# gemini:    gemini-2.0-flash (default), gemini-2.5-flash, gemini-1.5-pro, ...
# openai:    gpt-4o-mini (default), gpt-4o, o3-mini, ...
# anthropic: claude-sonnet-4-6 (default), claude-opus-4-7, claude-haiku-4-5-20251001, ...
# deepseek:  deepseek-chat (default), deepseek-reasoner, ...
MODEL_NAME=gemini-2.0-flash

# API key for the selected provider. Only the key matching MODEL_PROVIDER is required.
GOOGLE_API_KEY=your google API key
OPENAI_API_KEY=your openai API key
ANTHROPIC_API_KEY=your anthropic API key
DEEPSEEK_API_KEY=your deepseek API key

# Claude Workload Identity Federation Configuration
# Required when running agent-with-claude-wif.ts instead of agent.ts.
# Set up a federation rule in the Anthropic Console and fill in the values below.
# See: https://platform.claude.com/docs/en/manage-claude/workload-identity-federation
ANTHROPIC_FEDERATION_RULE_ID=fdrl_...
ANTHROPIC_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
ANTHROPIC_SERVICE_ACCOUNT_ID=svac_...
ANTHROPIC_WORKSPACE_ID=wrkspc_...
# Provide the IdP-issued JWT as either a direct value or a file path (one is required).
# Direct token value (useful in local/dev environments or when the token is injected via env).
ANTHROPIC_IDENTITY_TOKEN=
# Path to a file containing the JWT (e.g. a Kubernetes projected service account token).
ANTHROPIC_IDENTITY_TOKEN_FILE=/var/run/secrets/anthropic.com/token

# MCP server endpoint used by the agent.
MCP_SERVER_URL=http://localhost:8001/mcp

# Port used by the AI agent service.
AGENT_PORT=8791

# Host used by the AI agent service.
HOST=localhost

# Structured log level used by pino.
LOG_LEVEL=info

# Optional: set to false only when troubleshooting direct authorize client-secret handling.
INCLUDE_CLIENT_SECRET_IN_AUTHORIZE=true
